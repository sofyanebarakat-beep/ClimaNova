# WordPress MCP — environment variables
# Copy this file to .env and fill in your values

# Your WordPress site URL (no trailing slash)
WP_BASE_URL=https://your-site.com

# JWT token from WordPress (regenerate via WP Admin → JWT Auth plugin)
# OR use an Application Password (recommended for long-term use):
#   WP Admin → Users → Your Profile → Application Passwords → Add New
WP_JWT_TOKEN=your_jwt_token_here

# Optional: Application Password auth (alternative to JWT)
# Format: username:application_password (spaces removed)
# WP_APP_USER=admin
# WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
