Options -MultiViews
RewriteEngine On

# Redirect www to non-www (canonical domain)
RewriteCond %{HTTP_HOST} ^www\.climanova-energie\.fr [NC]
RewriteRule ^ https://climanova-energie.fr%{REQUEST_URI} [R=301,L]

# Redirect old /ClimaNova/ paths to root
RewriteRule ^ClimaNova/(.*)$ /$1 [R=301,L]

# Redirect deleted English blog template pages → /blog/
RewriteRule ^blog/5-common-home-repairs-you-can-do-yourself-this-weekend/?$ /blog/ [R=301,L]
RewriteRule ^blog/5-common-roof-repairs-you-can-easily-handle-yourself-safely/?$ /blog/ [R=301,L]
RewriteRule ^blog/budget-friendly-ways-to-upgrade-your-home-easily-and-cheaply/?$ /blog/ [R=301,L]
RewriteRule ^blog/how-to-choose-the-right-home-repair-service-quickly-and-safely/?$ /blog/ [R=301,L]
RewriteRule ^blog/how-to-extend-the-life-of-your-appliances-and-save-money/?$ /blog/ [R=301,L]
RewriteRule ^blog/preparing-your-home-for-essential-seasonal-maintenance-guide/?$ /blog/ [R=301,L]

# Redirect deleted template service pages → relevant ClimaNova service pages
RewriteRule ^services/appliance-installation/?$ /services/entretien/ [R=301,L]
RewriteRule ^services/furniture-repair/?$ /services/entretien/ [R=301,L]
RewriteRule ^services/home-remodeling/?$ /services/renovation-energetique/ [R=301,L]
RewriteRule ^services/kitchen-upgrade/?$ /services/renovation-energetique/ [R=301,L]
RewriteRule ^services/plumbing-leak-repairs/?$ /services/plomberie/ [R=301,L]
RewriteRule ^services/roof-and-wall-repair/?$ /services/renovation-energetique/ [R=301,L]

# Serve clean URLs (without .html)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Custom 404
ErrorDocument 404 /404.html
